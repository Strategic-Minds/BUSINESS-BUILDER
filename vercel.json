{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/5min",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/nightly-qa",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-seo",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/workflow-health",
      "schedule": "0 * * * *"
    }
  ]
}